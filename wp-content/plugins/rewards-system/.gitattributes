# Normalize line endings across platforms
* text=auto

# Source code
*.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf

# Documentation
*.md text eol=lf
LICENSE text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
