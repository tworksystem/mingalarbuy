<?xml version="1.0" encoding="utf-8"?>
<!-- PlanetMM Launch Splash Screen (API 21+) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background gradient aligned with PlanetMM primary app gradient
         (deep blue to purple) for a consistent brand experience -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#1A237E"
                android:centerColor="#4A148C"
                android:endColor="#6A1B9A" />
        </shape>
    </item>
    
    <!-- PlanetMM Logo (centered) -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/planetmm_inapplogo" />
    </item>
</layer-list>
